\u05d1\u05e8."],"Sender name":["\u05e9\u05dd \u05d4\u05e9\u05d5\u05dc\u05d7"],"Replies will be sent to the post author's email":["\u05d4\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05d9\u05d9\u05e9\u05dc\u05d7\u05d5 \u05dc\u05d0\u05d9\u05de\u05d9\u05d9\u05dc \u05e9\u05dc \u05de\u05d7\u05d1\u05e8 \u05d4\u05e4\u05d5\u05e1\u05d8"],"Replies are not allowed":["\u05d0\u05d9\u05df \u05d4\u05e8\u05e9\u05d0\u05d4 \u05dc\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea"],"Reply-to settings":["\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05e9\u05dc \u05de\u05e7\u05d1\u05dc\u05d9 \u05d4\u05ea\u05e9\u05d5\u05d1\u05d4"],"Show subscription pop-up when scrolling a post":["\u05d4\u05e6\u05d2 \u05d7\u05dc\u05d5\u05df \u05e7\u05d5\u05e4\u05e5 \u05dc\u05d4\u05e8\u05e9\u05de\u05d4 \u05dc\u05e2\u05d3\u05db\u05d5\u05e0\u05d9\u05dd \u05d1\u05de\u05d4\u05dc\u05da \u05d2\u05dc\u05d9\u05dc\u05d4 \u05d1\u05e4\u05d5\u05e1\u05d8"],"Add the Subscribe Block at the end of each post":["\u05d4\u05d5\u05e1\u05e3 \u05d0\u05ea \u05d4\u05d1\u05dc\u05d5\u05e7 '\u05d4\u05e8\u05e9\u05de\u05d4' \u05d1\u05e1\u05d5\u05e4\u05d5 \u05e9\u05dc \u05db\u05dc \u05e4\u05d5\u05e1\u05d8"],"Full text":["\u05ea\u05db\u05e0\u05d9\u05dd \u05de\u05dc\u05d0\u05d9\u05dd"],"For each new post email, include":["\u05d1\u05db\u05dc \u05d0\u05d9\u05de\u05d9\u05d9\u05dc \u05e2\u05dc \u05e4\u05d5\u05e1\u05d8 \u05d7\u05d3\u05e9, \u05d9\u05e9 \u05dc\u05db\u05dc\u05d5\u05dc"],"Sets whether email subscribers can read full posts in emails or just an excerpt and link to the full version of the post.":["\u05d4\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05de\u05d2\u05d3\u05d9\u05e8\u05d4 \u05d0\u05dd \u05de\u05e0\u05d5\u05d9\u05d9\u05dd \u05d1\u05d0\u05d9\u05de\u05d9\u05d9\u05dc \u05d9\u05db\u05d5\u05dc\u05d9\u05dd \u05dc\u05e7\u05e8\u05d5\u05d0 \u05e4\u05d5\u05e1\u05d8\u05d9\u05dd \u05de\u05dc\u05d0\u05d9\u05dd \u05d1\u05d0\u05d9\u05de\u05d9\u05d9\u05dc\u05d9\u05dd \u05d0\u05d5 \u05e8\u05e7 \u05ea\u05e7\u05e6\u05d9\u05e8 \u05d5\u05dc\u05dc\u05d7\u05d5\u05e5 \u05e2\u05dc 