u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0430 \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044c \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0456\u0432"],"Show result counts":["\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0438 \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044c \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456\u0432"],"Pick which registered taxonomy this filter targets. Built-in Category and Tag have their own dedicated filters in the inserter.":["\u0412\u0438\u0431\u0435\u0440\u0456\u0442\u044c, \u043d\u0430 \u044f\u043a\u0443 \u0437\u0430\u0440\u0435\u0454\u0441\u0442\u0440\u043e\u0432\u0430\u043d\u0443 \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u044e \u0434\u0456\u0454 \u0446\u0435\u0439 \u0444\u0456\u043b\u044c\u0442\u0440. \u0412\u0431\u0443\u0434\u043e\u0432\u0430\u043d\u0456 \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0456\u0457 \u0442\u0430 \u0442\u0435\u0433\u0438 \u043c\u0430\u044e\u0442\u044c \u0432\u043b\u0430\u0441\u043d\u0456 \u0441\u043f\u0435\u0446\u0456\u0430\u043b\u044c\u043d\u0456 \u0444\u0456\u043b\u044c\u0442\u0440\u0438 \u0432 \u0456\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0456 \u0434\u043e\u0434\u0430\u0432\u0430\u043d\u043d\u044f."],"No custom taxonomies registered on this site. Register one with register_taxonomy() and it will appear here.":["\u041d\u0430 \u0446\u044c\u043e\u043c\u0443 \u0441\u0430\u0439\u0442\u0456 \u043d\u0435 \u0437\u0430\u0440\u0435\u0454\u0441\u0442\u0440\u043e\u0432\u0430\u043d\u043e \u0436\u043e\u0434\u043d\u0438\u0445 \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0446\u044c\u043a\u0438\u0445 \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u0439. \u0417\u0430\u0440\u0435\u0454\u0441\u0442\u0440\u0443\u0439\u0442\u0435 \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u044e \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0444\u0443\u043d\u043a\u0446\u0456\u0457 register_taxonomy(), \u0456 \u0432\u043e\u043d\u0430 \u0437\u2019\u044f\u0432\u0438\u0442\u044c\u0441\u044f \u0442\u0443\u0442."],"Select a taxonomy":["\u0412\u0438\u0431\u0435\u0440\u0456\u0442\u044c \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u044e"],"Loading taxonomies\u2026":["\u0417\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043d\u044f \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u0439\u2026"],"What this filter groups results by. Switch without deleting the block.":["\u041a\u0440\u0438\u0442\u0435\u0440\u0456\u0439 \u0433\u0440\u0443\u043f\u0443\u0432\u0430\u043d\u043d\u044f \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456\u0432. \u0417\u043c\u0456\u043d\u044e\u0439\u0442\u0435 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0431\u0435\u0437 \u0432\u0438\u0434\u0430\u043b\u0435\u043d\u043d\u044f \u0431\u043b\u043e\u043a\u0443 \u0434\u0430\u043d\u0438\u0445."],"Custom taxonomy":["\u041a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0446\u044c\u043a\u0430 \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u044f"],"Filter type":["\u0422\u0438\u043f \u0444\u0456\u043b\u044c\u0442\u0440\u0430"],"Leave empty to use the variation's default label (e.g. Category, Tag).":["\u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u043b\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u0443 \u043d\u0430\u0437\u0432\u0443 \u0432\u0430\u0440\u0456\u0430\u043d\u0442\u0443 (\u043d\u0430\u043f\u0440\u0438\u043a\u043b\u0430\u0434, \u00ab\u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0456\u044f\u00bb, \u00ab\u0422\u0435\u0433\u0438\u00bb)."],"A label is required so visitors see a heading above this filter.":["\u041f\u0456\u0434\u043f\u0438\u0441 \u043e\u0431\u043e\u0432\u2019\u044f\u0437\u043a\u043e\u0432\u0438\u0439 \u0434\u043b\u044f \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436