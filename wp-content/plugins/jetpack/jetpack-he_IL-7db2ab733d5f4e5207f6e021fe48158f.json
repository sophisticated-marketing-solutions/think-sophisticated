d4\u05ea\u05e7\u05d9\u05df \u05d0\u05ea \u05d4\u05ea\u05d5\u05e1\u05e3."],"Create Salesforce lead form":["\u05dc\u05d9\u05e6\u05d5\u05e8 \u05d8\u05d5\u05e4\u05e1 \u05dc\u05d9\u05d3\u05d9\u05dd \u05e9\u05dc Salesforce"],"Configured per form":["\u05de\u05d5\u05d2\u05d3\u05e8 \u05dc\u05e4\u05d9 \u05d8\u05d5\u05e4\u05e1"],"You do not have permission to activate plugins.":["\u05d0\u05d9\u05df \u05dc\u05da \u05d4\u05e8\u05e9\u05d0\u05d4 \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05ea\u05d5\u05e1\u05e4\u05d9\u05dd."],"You do not have permission to install plugins.":["\u05d0\u05d9\u05df \u05dc\u05da \u05d4\u05e8\u05e9\u05d0\u05d4 \u05dc\u05d4\u05ea\u05e7\u05d9\u05df \u05ea\u05d5\u05e1\u05e4\u05d9\u05dd."],"Export responses":["\u05dc\u05d9\u05d9\u05e6\u05d0 \u05d0\u05ea \u05d4\u05ea\u05d2\u05d5\u05d1\u05d5\u05ea"],"Complete MailPoet setup":["\u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea \u05d4\u05d2\u05d3\u05e8\u05ea MailPoet"],"MailPoet icon":["\u05e1\u05de\u05dc \u05e9\u05dc MailPoet"],"MailPoet is active. There is one step left. Please complete <a>MailPoet setup<\/a>.":["\u05d4\u05e9\u05d9\u05e8\u05d5\u05ea \u05e9\u05dc MailPoet \u05e4\u05e2\u05d9\u05dc. \u05e0\u05d5\u05ea\u05e8 \u05e2\u05d5\u05d3 \u05e9\u05dc\u05d1 \u05d0\u05d7\u05d3. \u05e0\u05d0 \u05dc\u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05ea <a>\u05d4\u05d2\u05d3\u05e8\u05ea MailPoet<\/a>."],"You do not have any MailPoet lists yet. Click the dashboard button below to create one, or contacts will be added to a \"Jetpack Forms Subscribers\" list.":["\u05e2\u05d3\u05d9\u05d9\u05df \u05d0\u05d9\u05df \u05dc\u05da \u05e8\u05e9\u05d9\u05de\u05d5\u05ea \u05e9\u05dc MailPoet. \u05d9\u05e9 \u05dc\u05dc\u05d7\u05d5\u05e5 \u05e2\u05dc \u05db\u05e4\u05ea\u05d5\u05e8 \u05dc\u05d5\u05d7 \u05d4\u05d1\u05e7\u05e8\u05d4 \u05e9\u05dc\u05de\u05d8\u05d4 \u05db\u05d3\u05d9 \u05dc\u05d9\u05e6\u05d5\u05e8 \u05e8\u05e9\u05d9\u05de\u05d4, \u05d0\u05d7\u05e8\u05ea \u05d0\u05e0\u05e9\u05d9 \u05d4\u05e7\u05e9\u05e8 \u05d9\u05ea\u05d5\u05d5\u05e1\u05e4\u05d5 \u05dc\u05e8\u05e9\u05d9\u05de\u05ea \"\u05de\u05e0\u05d5\u05d9\u05d9\u05dd \u05e9\u05dc \u05d8\u05d5\u05e4\u05e1\u05d9 Jetpack\"."],"Which email list should contacts be added to?":["\u05dc\u05d0\u05d9\u05d6\u05d5 \u05e8\u05e9\u05d9\u05de\u05ea \u05d3\u05d5\u05d0\u05dc \u05d1\u05e8\u05e6\u05d5\u05e0\u05da \u05dc\u05d4\u05d5\u05e1\u05d9\u05e3 \u05d0\u05ea \u05d0\u05e0\u05e9\u05d9 \u05d4\u05e7\u05e9\u05e8?"],"Grow your audience with MailPoet":["\u05dc\u05d4\u05e8\u05d7\u05d9\u05d1 \u05d0\u05ea \u05e7\u05d4\u05dc \u05d4\u05e7\u05d5\u05e8\u05d0\u05d9\u05dd \u05e2\u05dd MailPoet"],"MailPoet is installed. Just activate the plugin to start sending emails.":["\u05d4\u05e9\u05d9\u05e8\u05d5\u05ea \u05e9\u05dc Akismet \u05de\u05d5\u05ea\u05e7\u05df. \u05db\u05d3\u05d9 \u05dc\u05d4\u05ea\u05d7\u05d9\u05dc \u05dc\u05e9\u05dc\u05d5\u05d7 \u05d0\u05d9\u05de\u05d9\u05d9\u05dc\u05d9\u05dd, \u05e4\u05e9\u05d5\u05d8 \u05e6\u05e8\u05d9\u05da \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d0\u05ea \u05d4\u05ea\u05d5\u05e1\u05e3."],"Add powerful email marketing to your forms with <a>MailPoet<\/a>. Simply install the plugin to start sending emails.":["\u05dc\u05d4\u05d5\u05e1\u05d9\u05e3 \u05e9\u05d9\u05d5\u05d5\u05e7 \u05e2\u05d5\u05e6\u05de\u05ea\u05d9 \u05d1\u05d0\u05d9\u05de\u05d9\u05d9\u05dc \u05dc\u05d8\u05e4\u05e1\u05d9\u05dd \u05e9\u05dc\u05da \u05d1\u05e2\u05d6\u05e8\u05ea <a>MailPoet<\/a>. \u05db\u05d3\u05d9 \u05dc\u05d4\u05ea\u05d7\u05d9\u05dc \u05dc\u05e9\u05dc\u05d5\u05d7 \u05d0\u05d9\u05de\u05d9\u05d9\u05dc\u05d9\u05dd, \u05e4\u05e9\u05d5\u05d8 \u05e6\u05e8\u05d9\u05da \u05dc\u05d4\u05ea\u05e7\u05d9\u05df \u05d0\u05ea \u05d4\u05ea\u05d5\u05e1\u05e3."],"Disconnect Google Drive":["\u05dc\u05d4\u05ea\u05e0\u05ea\u05e7 \u05de-Google Drive"],"View form responses":["\u05dc\u05d4\u05e6\u05d9\u05d2 \u05d0\u05ea \u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05d4\u05d8\u05d5\u05e4\u05e1"],"For integration with Salesforce to work, you must add specific fields with specific field IDs that match Salesforce.":["\u05db\u05d3\u05d9 \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d0\u05ea \u05d4\u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05e6\u05d9\u05d4 \u05e2\u05dd Salesforce, \u05e2\u05dc\u05d9\u05da \u05dc\u05d4\u05d5\u05e1\u05d9\u05e3 \u05e9\u05d3\u05d5\u05ea \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9\u05d9\u05dd \u05e2\u05dd \u05de\u05d6\u05d4\u05d9 \u05e9\u05d3\u05d5\u05ea \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9\u05d9\u05dd \u05e9\u05ea\u05d5\u05d0\u05de\u05d9\u05dd \u05dc-Salesforce."],"Salesforce connections are managed for each form individually in the block editor.":["\u05d4\u05d7\u05d9\u05d1\u05d5\u05e8\u05d9\u05dd \u05e9\u05dc Salesforce \u05de\u05e0\u05d5\u05d4\u05dc\u05d9\u05dd \u05d1\u05e2\u05d5\u05e8\u05da \u05d4\u05d1\u05dc\u05d5\u05e7\u05d9\u05dd, \u05e2\u05d1\u05d5\u05e8 \u05db\u05dc \u05d8\u05d5\u05e4\u05e1 \u05d1\u05e0\u05e4\u05e8\u05d3."],"Jetpack CRM is connected.":["Jetpack CRM \u05de\u05d7\u05d5\u05d1\u05e8."],"Create a form":["\u05d9\u05e6\u05d9\u05e8\u05ea \u05d8\u05d5\u05e4\u05e1"],"Akismet icon":["\u05d4\u05e1\u05de\u05dc \u05e9\u05dc Akismet"],"Enter organization ID":["\u05d9\u05e9 \u05dc\u05d4\u05d6\u05d9\u05df \u05d0\u05ea \u05de\u05d6\u05d4\u05d4 \u05d4\u05d0\u05e8\u05d2\u05d5\u05df"],"Enter a Salesforce Organization ID to enable.":["\u05d9\u05e9 \u05dc\u05d4\u05d6\u05d9\u05df \u05d0\u05ea \u05de\u05d6\u05d4\u05d4 \u05d4\u05d0\u05e8\u05d2\u05d5\u05df \u05e9\u05dc Salesforce \u05db\u05d3\u05d9 \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc."],"Plugin needs activation":["\u05d4\u05ea\u05d5\u05e1\u05e3 \u05d3\u05d5\u05e8\u05e9 \u05d4\u05e4\u05e2\u05dc\u05d4"],"Plugin needs install":["\u05d4\u05ea\u05d5\u05e1\u05e3 \u05d3\u05d5\u05e8\u05e9 \u05d4\u05ea\u05e7\u05e0\u05d4"],"Connect your site to Google Drive to export form responses directly to Google Sheets.":["\u05e0\u05d9\u05ea\u05df \u05dc\u05d7\u05d1\u05e8 \u05d0\u05ea \u05d4\u05d0\u05ea\u05e8 \u05e9\u05dc\u05da \u05dc-Google Drive \u05db\u05d3\u05d9 \u05dc\u05d9\u05d9\u05e6\u05d0 \u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05e2\u05dc \u05d8\u05e4\u05e1\u05d9\u05dd \u05d9\u05e9\u05d9\u05e8\u05d5\u05ea \u05d0\u05dc Google Sheets."],"Google Sheets is connected. You can export your form responses from the form responses page.":["\u05e9\u05d9\u05e8\u05d5\u05ea Google Sheets \u05de\u05d7\u05d5\u05d1\u05e8. \u05d0\u05e4\u05e9\u05e8 \u05dc\u05d9\u05d9\u05e6\u05d0 \u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05e2\u05dc \u05d8\u05e4\u05e1\u05d9\u05dd \u05d3\u05e8\u05da \u05e2\u05de\u05d5\u05d3 \u05d4\u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05e2\u05dc \u05d8\u05e4\u05e1\u05d9\u05dd."],"View stats and settings":["\u05dc\u05d4\u05e6\u05d9\u05d2 \u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05e1\u05d8\u05d8\u05d9\u05e1\u05d8\u05d9\u05d9\u05dd \u05d5\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea"],"Connect Jetpack user account":["\u05dc\u05d7\u05d1\u05e8 \u05d0\u05ea Jetpack \u05dc\u05d7\u05e9\u05d1\u05d5\u05df \u05d4\u05de\u05e9\u05ea\u05de\u05e9"],"Update Jetpack CRM":["\u05de\u05d5\u05de\u05dc\u05e5 \u05dc\u05e2\u05d3\u05db\u05df \u05d0\u05ea Jetpack"],"Open Jetpack CRM settings":["\u05dc\u05e4\u05ea\u05d5\u05d7 \u05d0\u05ea \u05d4\u05d2\u05d3\u05e8\u05d5\u05ea Jetpack CRM"],"Jetpack CRM is installed. To start saving contacts, simply activate the plugin.":["\u05e9\u05d9\u05e8\u05d5\u05ea Jetpack CRM \u05de\u05d5\u05ea\u05e7\u05df. \u05db\u05d3\u05d9 \u05dc\u05d4\u05ea\u05d7\u05d9\u05dc \u05dc\u05e9\u05de\u05d5\u05e8 \u05d0\u05ea \u05d0\u05e0\u05e9\u05d9 \u05d4\u05e7\u05e9\u05e8, \u05e8\u05e7 \u05e6\u05e8\u05d9\u05da \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d0\u05ea \u05d4\u05ea\u05d5\u05e1\u05e3."],"You can save your form contacts in <a>Jetpack CRM<\/a>. To get started, please install the plugin.":["\u05d0\u05e4\u05e9\u05e8 \u05dc\u05e9\u05de\u05d5\u05e8 \u05d0\u05ea \u05d0\u05e0\u05e9\u05d9 \u05d4\u05e7\u05e9\u05e8 \u05de\u05d8\u05e4\u05e1\u05d9\u05dd <a>\u05d1-Jetpack CRM<\/a>. \u05db\u05d3\u05d9 \u05dc\u05d4\u05ea\u05d7\u05d9\u05dc, \u05d9\u05e9 \u05dc\u05d4\u05ea\u05e7\u05d9\u05df \u05d0\u05ea \u05d4\u05ea\u05d5\u05e1\u05e3."],"This form is connected to Jetpack CRM.":["\u05d8\u05d5\u05e4\u05e1 \u05d6\u05d4 \u05de\u05d7\u05d5\u05d1\u05e8 \u05d0\u05dc Jetpack CRM."],"Install this plugin":["\u05dc\u05d4\u05ea\u05e7\u05d9\u05df \u05d0\u05ea \u05d4\u05ea\u05d5\u05e1\u05e3"],"Activate this plugin":["\u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05ea\u05d5\u05e1\u05e3 \u05d6\u05d4"],"Enable for this form":["\u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d1\u05d8\u05d5\u05e4\u05e1 \u05d4\u05d6\u05d4"],"Disable for this form":["\u05dc\u05d4\u05e9\u05d1\u05d9\u05ea \u05d1\u05d8\u05d5\u05e4\u05e1 \u05d4\u05d6\u05d4"],"Learn about Akismet":["\u05dc\u05de\u05d9\u05d3\u05e2 \u05e0\u05d5\u05e1\u05e3 \u05e2\u05dc Akismet"],"Your forms are automatically protected with Akismet.":["\u05e9\u05d9\u05e8\u05d5\u05ea Akismet \u05de\u05d2\u05df \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9\u05ea \u05e2\u05dc \u05d4\u05d8\u05e4\u05e1\u05d9\u05dd \u05e9\u05dc\u05da."],"We keep your forms protected":["\u05d0\u05e0\u05d7\u05e0\u05d5 \u05de\u05d2\u05d9\u05e0\u05d9\u05dd \u05e2\u05dc \u05d4\u05d8\u05e4\u05e1\u05d9\u05dd \u05e9\u05dc\u05da"],"Akismet is installed. Just activate the plugin to start blocking spam.":["\u05e9\u05d9\u05e8\u05d5\u05ea Akismet \u05de\u05d5\u05ea\u05e7\u05df. \u05db\u05d3\u05d9 \u05dc\u05d4\u05ea\u05d7\u05d9\u05dc \u05dc\u05d7\u05e1\u05d5\u05dd \u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05d6\u05d1\u05dc, \u05e4\u05e9\u05d5\u05d8 \u05e6\u05e8\u05d9\u05da \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05d0\u05ea \u05d4\u05ea\u05d5\u05e1\u05e3."],"Page %1$d of %2$d":["\u05e2\u05de\u05d5\u05d3 \u2066%1$d\u2069 \u05de\u05ea\u05d5\u05da \u2066%2$d\u2069"],"%s response deleted permanently.":["\u05ea\u05e9\u05d5\u05d1\u05d4 %s \u05e0\u05de\u05d7\u05e7\u05d4 \u05dc\u05e6\u05de\u05d9\u05ea\u05d5\u05ea.","%s \u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05e0\u05de\u05d7\u05e7\u05d5 \u05dc\u05e6\u05de\u05d9\u05ea\u05d5\u05ea."],"Response deleted permanently.":["\u05d4\u05ea\u05e9\u05d5\u05d1\u05d4 \u05e0\u05