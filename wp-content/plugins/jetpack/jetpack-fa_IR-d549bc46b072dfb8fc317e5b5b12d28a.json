 \u067e\u0627\u0633\u062e\u200c\u0647\u0627\u06cc \u0641\u0631\u0645 \u0631\u0627 \u0645\u0633\u062a\u0642\u06cc\u0645\u0627\u064b \u0628\u0647 \u06af\u0648\u06af\u0644 \u0634\u06cc\u062a \u0628\u0631\u0648\u0646\u200c\u0628\u0631\u06cc \u06a9\u0646\u06cc\u062f."],"Google Sheets is connected. You can export your form responses from the form responses page.":["\u06af\u0648\u06af\u0644 \u0634\u06cc\u062a \u0645\u062a\u0635\u0644 \u0627\u0633\u062a. \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u06cc\u062f \u067e\u0627\u0633\u062e\u200c\u0647\u0627\u06cc \u0641\u0631\u0645 \u062e\u0648\u062f \u0631\u0627 \u0627\u0632 \u0628\u0631\u06af\u0647 \u067e\u0627\u0633\u062e\u200c\u0647\u0627\u06cc \u0641\u0631\u0645 \u0628\u0631\u0648\u0646\u200c\u0628\u0631\u06cc \u06a9\u0646\u06cc\u062f."],"View stats and settings":["\u0645\u0634\u0627\u0647\u062f\u0647 \u0622\u0645\u0627\u0631 \u0648 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a"],"Form does not have integrations set up.":["\u0641\u0631\u0645\u060c \u0627\u062f\u063a\u0627\u0645 \u062a\u0646\u0638\u06cc\u0645\u200c\u0634\u062f\u0647\u200c\u0627\u06cc \u0646\u062f\u0627\u0631\u062f."],"Update Jetpack CRM":["\u0628\u0647\u200c\u0631\u0648\u0632\u0631\u0633\u0627\u0646\u06cc CRM \u062c\u062a\u200c\u067e\u06a9"],"Open Jetpack CRM settings":["\u0628\u0627\u0632 \u06a9\u0631\u062f\u0646 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a CRM \u062c\u062a\u200c\u067e\u06a9"],"Jetpack CRM is installed. To start saving contacts, simply activate the plugin.":["CRM \u062c\u062a\u200c\u067e\u06a9 \u0646\u0635\u0628 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0628\u0631\u0627\u06cc \u0634\u0631\u0648\u0639 \u0630\u062e\u06cc\u0631\u0647 \u0645\u062e\u0627\u0637\u0628\u06cc\u0646\u060c \u06a9\u0627\u0641\u06cc \u0627\u0633\u062a \u0627\u0641\u0632\u0648\u0646\u0647 \u0631\u0627 \u0641\u0639\u0627\u0644 \u06a9\u0646\u06cc\u062f."],"You can save your form contacts in <a>Jetpack CRM<\/a>. To get started, please install the plugin.":["\u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u06cc\u062f \u0645\u062e\u0627\u0637\u0628\u06cc\u0646 \u0641\u0631\u0645 \u062e\u0648\u062f \u0631\u0627 \u062f\u0631 <a>CRM \u062c\u062a\u200c\u067e\u06a9<\/a> \u0630\u062e\u06cc\u0631\u0647 \u06a9\u0646\u06cc\u062f. \u0628\u0631\u0627\u06cc \u0634\u0631\u0648\u0639\u060c \u0644\u0637\u0641\u0627\u064b \u0627\u0641\u0632\u0648\u0646\u0647 \u0631\u0627 \u0646\u0635\u0628 \u06a9\u0646\u06cc\u062f."],"This form is connected to Jetpack CRM.":["\u0627\u06cc\u0646 \u0641\u0631\u0645 \u0628\u0647 CRM \u062c\u062a\u200c\u067e\u06a9 \u0645\u062a\u0635\u0644 \u0627\u0633\u062a."],"Install this plugin":["\u0646\u0635\u0628 \u0627\u06cc\u0646 \u0627\u0641\u0632\u0648\u0646\u0647"],"Activate this plugin":["\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u0627\u06cc\u0646 \u0627\u0641\u0632\u0648\u0646\u0647"],"Enable for this form":["\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u0628\u0631\u0627\u06cc \u0627\u06cc\u0646 \u0641\u0631\u0645"],"Disable for this form":["\u063a\u06cc\u0631\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u0628\u0631\u0627\u06cc \u0627\u06cc\u0646 \u0641\u0631\u0645"],"Learn about Akismet":["\u062f\u0631\u0628\u0627\u0631\u0647 \u0622\u06a9\u06cc\u0633\u0645\u062a \u0628\u062f\u0627\u0646\u06cc\u062f"],"Your forms are automatically protected with Akismet.":["\u0641\u0631\u0645\u200c\u0647\u0627\u06cc \u0634\u0645\u0627 \u0628\u0647 \u0637\u0648\u0631 \u062e\u0648\u062f\u06a9\u0627\u0631 \u0628\u0627 \u0622\u06a9\u06cc\u0633\u0645\u062a \u0645\u062d\u0627\u0641\u0638\u062a \u0645\u06cc\u200c\u0634\u0648\u0646\u062f."],"We keep your forms protected":["\u0645\u0627 \u0641\u0631\u0645\u200c\u0647\u0627\u06cc \u0634\u0645\u0627 \u0631\u0627 \u0645\u062d\u0627\u0641\u0638\u062a \u0634\u062f\u0647 \u0646\u06af\u0647 \u0645\u06cc\u200c\u062f\u0627\u0631\u06cc\u0645"],"Akismet is installed. Just activate the plugin to start blocking spam.":["\u0622\u06a9\u06cc\u0633\u0645\u062a \u0646\u0635\u0628 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0641\u0642\u0637 \u0627\u0641\u0632\u0648\u0646\u0647 \u0631\u0627 \u0641\u0639\u0627\u0644 \u06a9\u0646\u06cc\u062f \u062a\u0627 \u0645\u0633\u062f\u0648\u062f\u0633\u0627\u0632\u06cc \u062c\u0641\u0646\u06af \u0622\u063a\u0627\u0632 \u0634\u0648\u062f."],"Manage integrations":["\u0645\u062f\u06cc\u0631\u06cc\u062a \u06cc\u06a9\u067e\u0627\u0631\u0686\u0647\u200c\u0633\u0627\u0632\u06cc\u200c\u0647\u0627"],"Add Akismet key":["\u0627\u0641\u0632\u0648\u062f\u0646 \u06a9\u0644\u06cc\u062f \u0627\u06a9\u06cc\u0633\u0645\u062a"],"Akismet is active. There is one step left. Please add your <a>Akismet key<\/a>.":["\u0627\u06a9\u06cc\u0633\u0645\u062a \u0641\u0639\u0627\u0644 \u0627\u0633\u062a. \u06cc\u06a9 \u0645\u0631\u062d\u0644\u0647 \u0628\u0627\u0642\u06cc \u0645\u0627\u0646\u062f\u0647 \u0627\u0633\u062a. \u0644\u0637\u0641\u0627\u064b <a>\u06a9\u0644\u06cc\u062f \u0627\u06a9\u06cc\u0633\u0645\u062a<\/a> \u062e\u0648\u062f \u0631\u0627 \u0627\u0636\u0627\u0641\u0647 \u06a9\u0646\u06cc\u062f."],"View spam":["\u0645\u0634\u0627\u0647\u062f\u0647 \u062c\u0641\u0646\u06af\u200c\u0647\u0627"],"Add one-click spam protection for your forms with <a>Akismet<\/a>. Simply install the plugin and you're set.":["\u0628\u0627 <a>\u0627\u06a9\u06cc\u0633\u0645\u062a<\/a>\u060c \u0628\u0627 \u06cc\u06a9 \u06a9\u0644\u06cc\u06a9 \u0627\u0632 \u0641\u0631\u0645\u200c\u0647\u0627\u06cc \u062e\u0648\u062f \u062f\u0631 \u0628\u0631\u0627\u0628\u0631 \u062c\u0641\u0646\u06af \u0645\u062d\u0627\u0641\u0638\u062a \u06a9\u0646\u06cc\u062f. \u0641\u0642\u0637 \u06a9\u0627\u0641\u06cc\u0633\u062a \u0627\u0641\u0632\u0648\u0646\u0647 \u0631\u0627 \u0646\u0635\u0628 \u06a9\u0646\u06cc\u062f \u062a\u0627 \u0647\u0645\u0647 \u0686\u06cc\u0632 \u0622\u0645\u0627\u062f\u0647 \u0634\u0648\u062f."],"Needs connection":["\u0646\u06cc\u0627\u0632 \u0628\u0647 \u0627\u062a\u0635\u0627\u0644"],"Connect to Google Drive":["\u0627\u062a\u0635\u0627\u0644 \u0628\u0647 \u06af\u0648\u06af\u0644 \u062f\u0631\u0627\u06cc\u0648"],"Where to find your Salesforce Organization ID":["\u0634\u0646\u0627\u0633\u0647 \u0633\u0627\u0632\u0645\u0627\u0646 Salesforce \u062e\u0648\u062f \u0631\u0627 \u0627\u0632 \u06a9\u062c\u0627 \u067e\u06cc\u062f\u0627 \u06a9\u0646\u06cc\u062f"],"Organization ID":["\u0634\u0646\u0627\u0633\u0647 \u0633\u0627\u0632\u0645\u0627\u0646"],"Invalid Organization ID. Should be a 15\u201318 characters long alphanumeric string.":["\u0634\u0646\u0627\u0633\u0647 \u0633\u0627\u0632\u0645\u0627\u0646 \u0646\u0627\u0645\u0639\u062a\u0628\u0631 \u0627\u0633\u062a. \u0628\u0627\u06cc\u062f \u06cc\u06a9 \u0631\u0634\u062a\u0647 \u0627\u0644\u0641\u0628\u0627\u06cc\u06cc \u0639\u062f\u062f\u06cc \u0628\u0647 \u0637\u0648\u0644 \u06f1\u06f5 \u062a\u0627 \u06f1\u06f8 \u06a9\u0627\u0631\u0627\u06a9\u062a\u0631 \u0628\u0627\u0634\u062f."],"Integrations":["\u0627\u062f\u063a\u0627\u0645"],"Please update to the latest version of the Jetpack CRM plugin to integrate your contact form with your CRM.":["\u0644\u0637\u0641\u0627\u064b \u0628\u0647 \u0622\u062e\u0631\u06cc\u0646 \u0646\u0633\u062e\u0647 \u0627\u0641\u0632\u0648\u0646\u0647 Jetpack CRM \u0628\u0631\u0648\u0632\u0631\u0633\u0627\u0646\u06cc \u06a9\u0646\u06cc\u062f \u062a\u0627 \u0641\u0631\u0645 \u062a\u0645\u0627\u0633 \u0634\u0645\u0627 \u0628\u0627 CRM \u0634\u0645\u0627 \u06cc\u06a9\u067e\u0627\u0631\u0686\u0647 \u0634\u0648\u062f."],"Jetpack Logo":["\u0622\u0631\u0645 Jetpack"],"Install":["\u0646\u0635\u0628"],"A site administrator must enable the CRM Jetpack Forms extension.":["\u06cc\u06a9 \u0645\u062f\u06cc\u0631 \u0633\u0627\u06cc\u062a \u0628\u0627\u06cc\u062f \u067e\u0633\u0648\u0646\u062f CRM Jetpack Forms \u0631\u0627 \u0641\u0639\u0627\u0644 \u06a9\u0646\u062f."],"Enable Jetpack Forms extension":["\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u0627\u0641\u0632\u0648\u0646\u0647 \u0641\u0631\u0645\u200c\u0647\u0627\u06cc \u062c\u062a\u200c\u067e\u06a9"],"You can integrate this contact form with Jetpack CRM by enabling Jetpack CRM's <a>Jetpack Forms extension<\/a>.":["\u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u06cc\u062f \u0628\u0627 \u0641\u0639\u0627\u0644 \u06a9\u0631\u062f\u0646 <a>\u0627\u0641\u0632\u0648\u0646\u0647 \u0641\u0631\u0645\u200c\u0647\u0627\u06cc \u062c\u062a\u200c\u067e\u06a9<\/a> \u0645\u0631\u0628\u0648\u0637 \u0628\u0647 CRM \u062c\u062a\u200c\u067e\u06a9\u060c \u0627\u06cc\u0646 \u0641\u0631\u0645 \u062a\u0645\u0627\u0633 \u0631\u0627 \u0628\u0627 \u0622\u0646 \u06cc\u06a9\u067e\u0627\u0631\u0686\u0647 \u06a9\u0646\u06cc\u062f."],"Installing\u2026":["\u0646\u0635\u0628"],"Activating\u2026":["\u0641\u0639\u0627\u0644 \u0633\u0627\u0632\u06cc"],"Connecting\u2026":["\u0628\u0631\u0642\u0631\u0627\u0631\u06cc \u0627\u0631\u062a\u0628\u0627\u0637..."],"Disconnecting\u2026":["\u0642\u0637\u0639 \u0627\u0631\u062a\u0628\u0627\u0637 ..."],"Enabled":["\u0641\u0639\u0627\u0644 \u0634\u062f"],"Activate":["\u0641\u0639\u0627\u0644 \u06a9\u0631\u062f\u0646"],"Refresh status":["\u062a\u0627\u0632\u0647\u200c\u0633\u0627\u0632\u06cc \u0648\u0636\u0639\u06cc\u062a"]}},"comment":{"reference":"jetpack_vendor\/automattic\/jetpack-forms\/dist\/blocks\/668.js"}}