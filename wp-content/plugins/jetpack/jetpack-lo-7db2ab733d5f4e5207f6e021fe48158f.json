5."],"Disconnect Google Drive":["\u0e95\u0eb1\u0e94\u0e81\u0eb2\u0e99\u0ec0\u0e8a\u0eb7\u0ec8\u0ead\u0ea1\u0e95\u0ecd\u0ec8 Google Drive"],"View form responses":["\u0ec0\u0e9a\u0eb4\u0ec8\u0e87\u0e81\u0eb2\u0e99\u0e95\u0ead\u0e9a\u0e81\u0eb1\u0e9a\u0e9f\u0ead\u0ea1"],"For integration with Salesforce to work, you must add specific fields with specific field IDs that match Salesforce.":["\u0ec0\u0e9e\u0eb7\u0ec8\u0ead\u0ec3\u0eab\u0ec9\u0e81\u0eb2\u0e99\u0ec0\u0e8a\u0eb7\u0ec8\u0ead\u0ea1\u0e95\u0ecd\u0ec8\u0e81\u0eb1\u0e9a Salesforce \u0ec0\u0eae\u0eb1\u0e94\u0ea7\u0ebd\u0e81\u0ec4\u0e94\u0ec9, \u0ec0\u0e88\u0ebb\u0ec9\u0eb2\u0e95\u0ec9\u0ead\u0e87\u0ec0\u0e9e\u0eb5\u0ec8\u0ea1\u0e9f\u0eb4\u0ea7\u0eaa\u0eb0\u0ec0\u0e9e\u0eb2\u0eb0\u0e9e\u0ec9\u0ead\u0ea1\u0e81\u0eb1\u0e9a ID \u0e82\u0ead\u0e87\u0e9f\u0eb4\u0ea7\u0e97\u0eb5\u0ec8\u0e81\u0ebb\u0e87\u0e81\u0eb1\u0e9a Salesforce."],"Salesforce connections are managed for each form individually in the block editor.":["\u0e81\u0eb2\u0e99\u0ec0\u0e8a\u0eb7\u0ec8\u0ead\u0ea1\u0e95\u0ecd\u0ec8 Salesforce \u0ec1\u0ea1\u0ec8\u0e99\u0e96\u0eb7\u0e81\u0e88\u0eb1\u0e94\u0e81\u0eb2\u0e99\u0eaa\u0eb3\u0ea5\u0eb1\u0e9a\u0ec1\u0e95\u0ec8\u0ea5\u0eb0\u0e9f\u0ead\u0ea1\u0ec1\u0e8d\u0e81\u0e81\u0eb1\u0e99\u0ea2\u0eb9\u0ec8\u0ec3\u0e99\u0e95\u0ebb\u0ea7\u0ec1\u0e81\u0ec9\u0ec4\u0e82\u0e9a\u0ea5\u0eb1\u0ead\u0e81."],"Jetpack CRM is connected.":["Jetpack CRM \u0ec0\u0e8a\u0eb7\u0ec8\u0ead\u0ea1\u0e95\u0ecd\u0ec8\u0ec1\u0ea5\u0ec9\u0ea7."],"Create a form":["\u0eaa\u0ec9\u0eb2\u0e87\u0e9f\u0ead\u0ea1"],"Akismet icon":["\u0ec4\u0ead\u0e84\u0ead\u0e99 Akismet"],"Enter organization ID":["\u0e9b\u0ec9\u0ead\u0e99 ID \u0ead\u0ebb\u0e87\u0e81\u0ead\u0e99"],"Plugin needs activation":["\u0e9b\u0ea5\u0eb1\u0e81\u0ead\u0eb4\u0e99\u0e95\u0ec9\u0ead\u0e87\u0ec4\u0e94\u0ec9\u0eae\u0eb1\u0e9a\u0e81\u0eb2\u0e99\u0ec0\u0e9b\u0eb5\u0e94\u0ec3\u0e8a\u0ec9\u0e87\u0eb2\u0e99"],"Plugin needs install":["\u0e9b\u0ea5\u0eb1\u0e81\u0ead\u0eb4\u0e99\u0e95\u0ec9\u0ead\