onger work.":["\u067e\u0633 \u0627\u0632 \u0642\u0637\u0639 \u0627\u062a\u0635\u0627\u0644 Jetpack\u060c \u0627\u06cc\u0646\u0647\u0627 \u062f\u06cc\u06af\u0631 \u06a9\u0627\u0631 \u0646\u062e\u0648\u0627\u0647\u0646\u062f \u06a9\u0631\u062f."],"Jetpack is currently powering multiple products on your site.":["Jetpack \u062f\u0631 \u062d\u0627\u0644 \u062d\u0627\u0636\u0631 \u0686\u0646\u062f\u06cc\u0646 \u0645\u062d\u0635\u0648\u0644 \u0631\u0627 \u062f\u0631 \u0633\u0627\u06cc\u062a \u0634\u0645\u0627 \u062a\u0627\u0645\u06cc\u0646 \u0645\u06cc \u06a9\u0646\u062f."],"Back to my website":["\u0628\u0627\u0632\u06af\u0634\u062a \u0628\u0647 \u0633\u0627\u06cc\u062a"],"No thank you":["\u0646\u0647 \u0645\u0645\u0646\u0648\u0646"],"Help us improve":["\u0628\u0647 \u0645\u0627 \u06a9\u0645\u06a9 \u06a9\u0646 \u062a\u0627 \u067e\u06cc\u0634\u0631\u0641\u062a \u06a9\u0646\u06cc\u0645"],"We\u2019re sorry to see you go. Here at Jetpack, we\u2019re always striving to provide the best experience for our customers. Please take our short survey (2 minutes, promise).":["\u0627\u0632 \u0631\u0641\u062a\u0646 \u0634\u0645\u0627 \u0645\u062a\u0627\u0633\u0641\u06cc\u0645. \u062f\u0631 \u0627\u06cc\u0646\u062c\u0627 \u062f\u0631 Jetpack\u060c \u0645\u0627 \u0647\u0645\u06cc\u0634\u0647 \u062f\u0631 \u062a\u0644\u0627\u0634 \u0647\u0633\u062a\u06cc\u0645 \u062a\u0627 \u0628\u0647\u062a\u0631\u06cc\u0646 \u062a\u062c\u0631\u0628\u0647 \u0631\u0627 \u0628\u0631\u0627\u06cc \u0645\u0634\u062a\u0631\u06cc\u0627\u0646 \u062e\u0648\u062f \u0627\u0631\u0627\u0626\u0647 \u062f\u0647\u06cc\u0645. \u0644\u0637\u0641\u0627 \u062f\u0631 \u0646\u0638\u0631\u0633\u0646\u062c\u06cc \u06a9\u0648\u062a\u0627\u0647 \u0645\u0627 \u0634\u0631\u06a9\u062a \u06a9\u0646\u06cc\u062f (2 \u062f\u0642\u06cc\u0642\u0647\u060c \u0642\u0648\u0644 \u062f\u0647\u06cc\u062f)."],"Jetpack has been <br\/>successfully disconnected.":["\u062c\u062a \u067e\u06a9 \u0628\u0648\u062f\u0647 \u0627\u0633\u062a<br\/> \u0628\u0627 \u0645\u0648\u0641\u0642\u06cc\u062a \u0642\u0637\u0639 \u0634\u062f"],"Are you sure you want to disconnect?":["\u0622\u06cc\u0627 \u0645\u0637\u0645\u0626\u0646\u06cc\u062f \u06a9\u0647 \u0645\u06cc \u062e\u0648\u0627\u0647\u06cc\u062f \u0627\u0631\u062a\u0628\u0627\u0637 \u0631\u0627 \u0642\u0637\u0639 \u06a9\u0646\u06cc\u062f\u061f"],"Disconnect":["\u0642\u0637\u0639 \u0627\u0631\u062a\u0628\u0627\u0637"],"Jetpack is powering other plugins on your site. If you disconnect, these plugins will no longer work.":["\u062c\u062a \u067e\u06a9 \u062f\u06cc\u06af\u0631 \u0627\u0641\u0632\u0648\u0646\u0647 \u0647\u0627\u06cc \u0633\u0627\u06cc\u062a \u0634\u0645\u0627 \u0631\u0627 \u062a\u0627\u0645\u06cc\u0646 \u0645\u06cc \u06a9\u0646\u062f. \u0627\u06af\u0631 \u0627\u062a\u0635\u0627\u0644 \u0631\u0627 \u0642\u0637\u0639 \u06a9\u0646\u06cc\u062f\u060c \u0627\u06cc\u0646 \u0627\u0641\u0632\u0648\u0646\u0647 \u0647\u0627 \u062f\u06cc\u06af\u0631 \u06a9\u0627\u0631 \u0646\u0645\u06cc \u06a9\u0646\u0646\u062f."],"Set up Jetpack":["Jetpack \u0631\u0627 \u0631\u0627\u0647 \u0627\u0646\u062f\u0627\u0632\u06cc \u06a9\u0646\u06cc\u062f"],"Over 5 million WordPress sites are faster and more secure":["\u0628\u06cc\u0634 \u0627\u0632 5 \u0645\u06cc\u0644\u06cc\u0648\u0646 \u0633\u0627\u06cc\u062a \u0648\u0631\u062f\u067e\u0631\u0633 \u0633\u0631\u06cc\u0639\u062a\u0631 \u0648 \u0627\u0645\u0646 \u062a\u0631 \u0647\u0633\u062a\u0646\u062f"],"\/month, paid yearly":["\/\u0645\u0627\u0647\u060c \u0633\u0627\u0644\u0627\u0646\u0647 \u067e\u0631\u062f\u0627\u062e\u062a \u0645\u06cc \u0634\u0648\u062f"],"Icon for the product %s":["\u0646\u0645\u0627\u062f \u0645\u062d\u0635\u0648\u0644 %s"],"An error occurred. Please try again.":["\u062e\u0637\u0627\u06cc\u06cc \u0631\u062e \u062f\u0627\u062f\u0647 \u0627\u0633\u062a. \u0644\u0637\u0641\u0627 \u062f\u0648\u0628\u0627\u0631\u0647 \u062a\u0644\u0627\u0634 \u06a9\u0646\u06cc\u062f."],"Jetpack Logo":["\u0622\u0631\u0645 Jetpack"]}},"comment":