u0633\u0627\u0644\u0627\u0646\u0647"],"Using <strong>%1$dGB<\/strong> of %2$dTB":["\u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 <strong>%1$dGB<\/strong> \u0627\u0632 %2$dTB"],"Using <strong>%1.1fGB<\/strong> of %2fGB":["\u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 <strong>%1.1f \u06af\u06cc\u06af\u0627\u0628\u0627\u06cc\u062a<\/strong> \u0627\u0632 %2f \u06af\u06cc\u06af\u0627\u0628\u0627\u06cc\u062a"],"%1$dGB used":["%1$d \u06af\u06cc\u06af\u0627\u0628\u0627\u06cc\u062a \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0634\u062f\u0647 \u0627\u0633\u062a"],"<a>%s days of backups saved<\/a>":["<a>%s \u0631\u0648\u0632 \u067e\u0634\u062a\u06cc\u0628\u0627\u0646 \u0630\u062e\u06cc\u0631\u0647 \u0634\u062f<\/a>"],"<a>1 day of backups saved<\/a>":["<a>1 \u0631\u0648\u0632 \u067e\u0634\u062a\u06cc\u0628\u0627\u0646 \u0630\u062e\u06cc\u0631\u0647 \u0634\u062f<\/a>"],"We removed your oldest backup(s) to make space for new ones. We will continue to remove old backups as needed, up to the last %s days.":["\u0645\u0627 \u0642\u062f\u06cc\u0645\u06cc\u200c\u062a\u0631\u06cc\u0646 \u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u200c\u0647\u0627 \u0631\u0627 \u062d\u0630\u0641 \u06a9\u0631\u062f\u06cc\u0645 \u062a\u0627 \u0641\u0636\u0627\u06cc\u06cc \u0628\u0631\u0627\u06cc \u0645\u0648\u0627\u0631\u062f \u062c\u062f\u06cc\u062f \u0627\u06cc\u062c\u0627\u062f \u06a9\u0646\u06cc\u0645. \u0645\u0627 \u0628\u0647 \u062d\u0630\u0641 \u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u200c\u0647\u0627\u06cc \u0642\u062f\u06cc\u0645\u06cc \u062f\u0631 \u0635\u0648\u0631\u062a \u0646\u06cc\u0627\u0632\u060c \u062a\u0627 %s \u0631\u0648\u0632 \u06af\u0630\u0634\u062a\u0647 \u0627\u062f\u0627\u0645\u0647 \u062e\u0648\u0627\u0647\u06cc\u0645 \u062f\u0627\u062f."],"You have reached your storage limit with %s day(s) of backups saved. Backups have been stopped. Please upgrade your storage to resume backups.":["\u0628\u0627 \u0630\u062e\u06cc\u0631\u0647\u200c\u0633\u0627\u0632\u06cc %s \u0631\u0648\u0632 \u067e\u0634\u062a\u06cc\u0628\u0627\u0646 \u0628\u0647 \u062d\u062f \u0645\u062c\u0627\u0632 \u0641\u0636\u0627\u06cc \u0630\u062e\u06cc\u0631\u0647\u200c\u0633\u0627\u0632\u06cc \u062e\u0648\u062f \u0631\u0633\u06cc\u062f\u0647\u200c\u0627\u06cc\u062f. \u067e\u0634\u062a\u06cc\u0628\u0627\u0646 \u06af\u06cc\u0631\u06cc \u0645\u062a\u0648\u0642\u0641 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0644\u0637\u0641\u0627\u064b \u0641\u0636\u0627\u06cc \u0630\u062e\u06cc\u0631\u0647\u200c\u0633\u0627\u0632\u06cc \u062e\u0648\u062f \u0631\u0627 \u0628\u0631\u0627\u06cc \u0627\u0632\u0633\u0631\u06af\u06cc\u0631\u06cc \u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u200c\u06af\u06cc\u0631\u06cc \u0627\u0631\u062a\u0642\u0627 \u062f\u0647\u06cc\u062f."],"You are very close to reaching your storage limit. Once you do, we will delete your oldest backups to make space for new ones.":["\u0634\u0645\u0627 \u0628\u0633\u06cc\u0627\u0631 \u0646\u0632\u062f\u06cc\u06a9 \u0628\u0647 \u0631\u0633\u06cc\u062f\u0646 \u0628\u0647 \u062d\u062f \u0645\u062c\u0627\u0632 \u0641\u0636\u0627\u06cc \u0630\u062e\u06cc\u0631\u0647 \u0633\u0627\u0632\u06cc \u062e\u0648\u062f \u0647\u0633\u062a\u06cc\u062f. \u067e\u0633 \u0627\u0632 \u0627\u0646\u062c\u0627\u0645 \u0627\u06cc\u0646 \u06a9\u0627\u0631\u060c \u0645\u0627 \u0642\u062f\u06cc\u0645\u06cc\u200c\u062a\u0631\u06cc\u0646 \u0646\u0633\u062e\u0647\u200c\u0647\u0627\u06cc \u067e\u0634\u062a\u06cc\u0628\u0627\u0646 \u0634\u0645\u0627 \u0631\u0627 \u062d\u0630\u0641 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u0645 \u062a\u0627 \u0641\u0636\u0627\u06cc\u06cc \u0628\u0631\u0627\u06cc \u0645\u0648\u0627\u0631\u062f \u062c\u062f\u06cc\u062f \u0627\u06cc\u062c\u0627\u062f \u06a9\u0646\u06cc\u0645."],"You are close to reaching your storage limit. Once you do, we will delete your oldest backups to make space for new ones.":["\u0634\u0645\u0627 \u062f\u0631 \u0622\u0633\u062a\u0627\u0646\u0647 \u0631\u0633\u06cc\u062f\u0646 \u0628\u0647 \u062d\u0