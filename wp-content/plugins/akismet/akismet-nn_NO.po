msgid_plural "<a href=\"%1$s\">Akismet</a> has protected your site from %2$s spam comments already. "
msgstr[0] "<a href=\"%1$s\">Akismet</a> har allereie verna nettstaden din frå %2$s søppelkommentar. "
msgstr[1] "<a href=\"%1$s\">Akismet</a> har allereie verna nettstaden din frå %2$s søppelkommentarar. "

#: class.akismet-admin.php:1276
msgid "Cleaning up spam takes time."
msgstr "Rydde opp i søppelpost tek tid."

#. translators: The placeholder is an error response returned by the API
#. server.
#: class.akismet-admin.php:774
msgid "Akismet was unable to check this comment (response: %s) but will automatically retry later."
msgstr "Akismet var ikkje i stand til å kontrolere denne kommentaren (tilbakemelding: %s) men vil automatisk prøve på nytt seinare."

#. translators: %1$s is a username; %2$s is a short string (like 'spam' or
#. 'approved') denoting the new comment status.
#: class.akismet-admin.php:817
msgid "%1$s changed the comment status to %2$s."
msgstr "%1$s endra kommentarstatusen til %2$s."

#. translators: The placeholder is an error response returned by the API
#. server.
#: class.akismet-admin.php:782
msgid "Akismet was unable to recheck this comment (response: %s)."
msgstr "Akismet var ikkje i stand til å kontrollera denne kommentaren på nytt (tilbakemelding: %s)."

#: class.akismet-admin.php:288
msgid "On this page, you are able to view stats on spam filtered on your site."
msgstr "På denne sida, kan du sjå statestikk over søppelpost funne på nettstaden din."

#: views/config.php:175
msgid "Silently discard the worst and most pervasive spam so I never see it."
msgstr "Utan eit ord forkast den verste og mest gjennomgripande søppelposten slik at eg aldri ser den."

#: class.akismet-admin.php:312
msgid "Choose to either discard the worst spam automatically or to always put all spam in spam folder."
msgstr "Vel enten å forkaste den verste søppelposten automatisk eller legg den alltid i søppelpostmappa."

#: views/notice.php:172
msgid "There is a problem with your API key."
msgstr "Der eit problem med API-nøkkelen din."

#: views/notice.php:37
msgid "Some comments have not yet been checked for spam by Akismet. They have been temporarily held for moderation and will automatically be rechecked later."
msgstr "Nokre kommentarar har ikkje blitt kontrollert for søppelpost av Aksimet. Dei har vorte haldne tilbake for gjennomgang og vert atomatisk kontrollert seinare."

#. translators: The Akismet configuration page URL.
#: class.akismet-admin.php:1148
msgid "Please check your <a href=\"%s\">Akismet configuration</a> and contact your web host if problems persist."
msgstr "Kontroller <a href=\"%s\">Akismet oppsettet</a> og kontakt vevtilbydaren din dersom problemet vedvarer."

#: views/config.php:318
msgid "Active"
msgstr "Verksam"

#: class.akismet-admin.php:324
msgid "The subscription status - active, cancelled or suspended"
msgstr "Abonnementstatusen - verksam, avbroten eller oppheva"

#: views/config.php:190
msgid "Note:"
msgstr "Merk:"

